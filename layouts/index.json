[
    {{- range $i, $e := .Site.RegularPages -}}
    {{- if $i -}},{{- end -}}
    {{- dict "title" .Title "date" (.Date.Format "2006-01-02") "summary" .Summary "content" .Plain "permalink" .Permalink "section" .Section "tags" .Params.tags "categories" .Params.categories "image" .Params.image | jsonify -}}
    {{- end -}}
]