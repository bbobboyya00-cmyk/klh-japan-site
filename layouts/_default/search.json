[
{{- range $i, $e := .Site.RegularPages -}}
    {{- if $i -}},{{- end -}}
    {{- $data := dict "title" .Title "date" (.Date.Format "2006-01-02") "permalink" .RelPermalink "content" .Plain -}}
    {{- $image := partial "helper/image" (dict "Image" .Params.image "Resources" .Resources "Context" .) -}}
    {{- if $image -}}
        {{- $data = merge $data (dict "image" $image.RelPermalink) -}}
    {{- end -}}
    {{- $data | jsonify -}}
{{- end -}}
]
