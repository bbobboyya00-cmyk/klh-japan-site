[
{{- range $i, $e := (partial "helper/pages.html" .Site.Home) -}}
    {{- if $i -}},{{- end -}}
    {{- /* 본문에서 태그 제거 후 200자만 추출하여 가볍게 만듦 */ -}}
    {{- $summary := .Plain | plainify | truncate 200 -}}
    {{- $data := dict "title" .Title "date" (.Date.Format "2006-01-02T15:04:05Z") "permalink" .RelPermalink "content" $summary -}}
    {{- $image := partial "helper/image" (dict "Image" .Params.image "Resources" .Resources "Context" .) -}}
    {{- if $image -}}
        {{- $data = merge $data (dict "image" $image.Permalink) -}}
    {{- end -}}
    {{- $data | jsonify -}}
{{- end -}}
]
